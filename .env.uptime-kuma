# Uptime Kuma Sync Configuration
# Copy this file to .env.uptime-kuma.local and fill in your actual credentials

# Source Instance (the one to copy FROM)
SOURCE_UPTIME_URL=http://localhost:3001
SOURCE_UPTIME_USER=admin
SOURCE_UPTIME_PASS=your-password-here

# Target Instance (the one to copy TO)
TARGET_UPTIME_URL=http://localhost:3002
TARGET_UPTIME_USER=admin
TARGET_UPTIME_PASS=your-password-here

# Backup Directory (optional, default: ./uptime-kuma-backups)
BACKUP_DIR=./uptime-kuma-backups
