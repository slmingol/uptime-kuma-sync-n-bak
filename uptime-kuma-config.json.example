# Copy this file to uptime-kuma-config.json and configure your instances
{
  "instances": {
    "primary": {
      "url": "https://uptime1.example.com",
      "username": "admin",
      "password": "your-password-here",
      "description": "Primary production monitoring instance"
    },
    "secondary": {
      "url": "https://uptime2.example.com",
      "username": "admin",
      "password": "your-password-here",
      "description": "Secondary/backup monitoring instance"
    },
    "local-dev": {
      "url": "http://localhost:3001",
      "username": "admin",
      "password": "admin",
      "description": "Local development instance"
    }
  },
  "backup": {
    "directory": "./uptime-kuma-backups"
  },
  "sync": {
    "mode": "shallow",
    "excludedFields": [
      "interval",
      "retryInterval",
      "resendInterval",
      "maxretries",
      "timeout",
      "upside_down",
      "maxredirects",
      "accepted_statuscodes",
      "dns_resolve_type",
      "dns_resolve_server",
      "notificationIDList"
    ]
  },
  "_comments": {
    "sync.mode": "Set to 'shallow' (default) to preserve instance-specific settings, or 'deep' to copy everything. Can be overridden with --deep or --shallow flags.",
    "sync.excludedFields": "Fields to exclude in shallow mode. In deep mode, all fields are copied regardless of this list."
  }
}
