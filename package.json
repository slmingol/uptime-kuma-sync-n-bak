  "description": "Sync monitors and groups between multiple Uptime Kuma instances while preserving instance-specific settings. Includes automatic backup and restore functionality.",
  "main": "uptime-kuma-sync.js",
  "scripts": {
    "sync": "node uptime-kuma-sync.js",
    "backup": "node uptime-kuma-backup.js",
    "restore": "node uptime-kuma-restore.js",
