    "postversion": "node -p \"require('./package.json').version\" > VERSION && git add VERSION && git commit -m 'Update VERSION file' && echo 'VERSION file updated'"
  },
  "keywords": [
    "uptime-kuma",
    "monitoring",
    "sync",
    "backup",
    "restore",
    "multi-instance",
    "high-availability"
  ],
